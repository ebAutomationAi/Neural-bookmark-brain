#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Script de Preparación de Auditoría para Neural Bookmark Brain
Genera un archivo único consolidado con todo el código fuente del proyecto
para análisis, documentación o auditorías de código.
"""

import os
import datetime
from pathlib import Path

# Directorios y archivos a incluir en la auditoría
DIRECTORIOS_INCLUIR = [
    "app",
    "scripts",
    "data",
]

ARCHIVOS_INCLUIR_RAIZ = [
    "docker-compose.yml",
    "Dockerfile",
    "requirements.txt",
    "README.md",
    ".env.example",
]

EXTENSIONES_PERMITIDAS = [
    '.py',          # Python
    '.yml',         # YAML
    '.yaml',        # YAML
    '.json',        # JSON
    '.sql',         # SQL
    '.md',          # Markdown
    '.txt',         # Texto
    '.dockerfile',  # Dockerfile
    '.env',         # Environment
    '.example',     # Ejemplos de config
]

EXTENSIONES_EXCLUIR = [
    '.pyc', '.pyo', '.pyd',  # Compilados Python
    '.db', '.sqlite', '.sqlite3',  # Bases de datos
    '.log',  # Logs
    '.pid', '.sock',  # Procesos/sockets
]

NOMBRES_EXCLUIR = [
    '__pycache__',
    '.git',
    '.venv',
    'venv',
    'env',
    '.env',
    '.pytest_cache',
    '.mypy_cache',
    '.coverage',
    'htmlcov',
    '.tox',
    'dist',
    'build',
    '*.egg-info',
    'node_modules',
    '.DS_Store',
    'Thumbs.db',
    'desktop.ini',
]

ARCHIVO_SALIDA = "auditoria_completa_neural_bookmark_brain.txt"

def obtener_tree(directorio=".", prefijo=""):
    """Genera una representación en árbol del directorio."""
    lines = []
    try:
        items = sorted(os.listdir(directorio))
    except PermissionError:
        return []
    
    # Filtrar items excluidos
    items = [item for item in items if not any(excl in item for excl in NOMBRES_EXCLUIR)]
    
    for i, item in enumerate(items):
        ruta = os.path.join(directorio, item)
        es_ultimo = i == len(items) - 1
        conector = "└── " if es_ultimo else "├── "
        
        lines.append(prefijo + conector + item)
        
        if os.path.isdir(ruta):
            extension = "    " if es_ultimo else "│   "
            lines.extend(obtener_tree(ruta, prefijo + extension))
    
    return lines

def incluir_archivo(ruta_archivo):
    """Determina si un archivo debe ser incluido en la auditoría."""
    nombre = os.path.basename(ruta_archivo)
    _, ext = os.path.splitext(nombre)
    ext = ext.lower()
    
    # Excluir por nombre
    if any(excl in nombre for excl in NOMBRES_EXCLUIR):
        return False
    
    # Excluir por extensión prohibida
    if ext in EXTENSIONES_EXCLUIR:
        return False
    
    # Incluir si está en la lista de extensiones permitidas
    if ext in EXTENSIONES_PERMITIDAS:
        return True
    
    # Archivos específicos de configuración sin extensión
    if nombre in ['Dockerfile', 'docker-compose.yml', 'docker-compose.yaml', '.env', '.env.example']:
        return True
    
    return False

def leer_archivo_seguro(ruta, encoding='utf-8'):
    """Lee un archivo de forma segura con manejo de errores de encoding."""
    try:
        with open(ruta, 'r', encoding=encoding) as f:
            return f.read()
    except UnicodeDecodeError:
        try:
            with open(ruta, 'r', encoding='latin-1') as f:
                return f.read()
        except Exception as e:
            return f"[ERROR: No se pudo leer el archivo - {str(e)}]"
    except Exception as e:
        return f"[ERROR: {str(e)}]"

def generar_auditoria():
    """Función principal que genera el archivo de auditoría."""
    print("🔍 Iniciando preparación de auditoría para Neural Bookmark Brain...")
    print(f"📁 Directorio de trabajo: {os.path.abspath('.')}")
    
    lineas_salida = []
    
    # Header
    lineas_salida.append("=" * 80)
    lineas_salida.append("AUDITORÍA COMPLETA - NEURAL BOOKMARK BRAIN")
    lineas_salida.append("=" * 80)
    lineas_salida.append(f"Fecha de generación: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    lineas_salida.append(f"Script: preparar_auditoria_bookmark.py")
    lineas_salida.append("")
    
    # Descripción del proyecto
    lineas_salida.append("-" * 80)
    lineas_salida.append("DESCRIPCIÓN DEL PROYECTO")
    lineas_salida.append("-" * 80)
    lineas_salida.append("Sistema de Base de Conocimiento Semántico potenciado por IA")
    lineas_salida.append("Transforma bookmarks desordenados en una base de conocimiento")
    lineas_salida.append("inteligente, categorizada y semánticamente buscable.")
    lineas_salida.append("")
    lineas_salida.append("Stack Tecnológico:")
    lineas_salida.append("  - Python 3.11+")
    lineas_salida.append("  - FastAPI")
    lineas_salida.append("  - PostgreSQL + pgvector")
    lineas_salida.append("  - SQLAlchemy (async)")
    lineas_salida.append("  - Sentence Transformers (embeddings)")
    lineas_salida.append("  - Groq API (LLMs)")
    lineas_salida.append("  - Trafilatura (web scraping)")
    lineas_salida.append("")
    
    # Estructura de directorios
    lineas_salida.append("-" * 80)
    lineas_salida.append("ESTRUCTURA DE DIRECTORIOS")
    lineas_salida.append("-" * 80)
    tree = obtener_tree()
    lineas_salida.extend(tree)
    lineas_salida.append("")
    lineas_salida.append("")
    
    # Contenido de archivos de raíz
    lineas_salida.append("=" * 80)
    lineas_salida.append("ARCHIVOS DE CONFIGURACIÓN Y RAÍZ")
    lineas_salida.append("=" * 80)
    lineas_salida.append("")
    
    for archivo in ARCHIVOS_INCLUIR_RAIZ:
        ruta = os.path.join(".", archivo)
        if os.path.exists(ruta) and os.path.isfile(ruta):
            lineas_salida.append("-" * 60)
            lineas_salida.append(f"ARCHIVO: {archivo}")
            lineas_salida.append(f"RUTA: {os.path.abspath(ruta)}")
            lineas_salida.append("-" * 60)
            contenido = leer_archivo_seguro(ruta)
            lineas_salida.append(contenido)
            lineas_salida.append("")
            lineas_salida.append("")
    
    # Contenido de directorios específicos
    for dir_name in DIRECTORIOS_INCLUIR:
        dir_path = os.path.join(".", dir_name)
        if not os.path.exists(dir_path):
            print(f"⚠️  Directorio no encontrado: {dir_name}")
            continue
        
        print(f"📂 Procesando directorio: {dir_name}")
        
        lineas_salida.append("=" * 80)
        lineas_salida.append(f"DIRECTORIO: {dir_name.upper()}")
        lineas_salida.append("=" * 80)
        lineas_salida.append("")
        
        for root, dirs, files in os.walk(dir_path):
            # Filtrar directorios excluidos
            dirs[:] = [d for d in dirs if not any(excl in d for excl in NOMBRES_EXCLUIR)]
            
            for file in files:
                file_path = os.path.join(root, file)
                
                if incluir_archivo(file_path):
                    rel_path = os.path.relpath(file_path, ".")
                    lineas_salida.append("-" * 60)
                    lineas_salida.append(f"ARCHIVO: {file}")
                    lineas_salida.append(f"RUTA RELATIVA: {rel_path}")
                    lineas_salida.append(f"RUTA ABSOLUTA: {os.path.abspath(file_path)}")
                    lineas_salida.append("-" * 60)
                    
                    contenido = leer_archivo_seguro(file_path)
                    lineas_salida.append(contenido)
                    lineas_salida.append("")
                    lineas_salida.append("")
    
    # Resumen
    lineas_salida.append("=" * 80)
    lineas_salida.append("RESUMEN DE LA AUDITORÍA")
    lineas_salida.append("=" * 80)
    lineas_salida.append(f"Total de líneas generadas: {len(lineas_salida)}")
    lineas_salida.append(f"Archivo de salida: {ARCHIVO_SALIDA}")
    lineas_salida.append("")
    lineas_salida.append("FIN DE LA AUDITORÍA")
    lineas_salida.append("=" * 80)
    
    # Escribir archivo
    contenido_final = "\n".join(lineas_salida)
    
    with open(ARCHIVO_SALIDA, 'w', encoding='utf-8') as f:
        f.write(contenido_final)
    
    print(f"✅ Auditoría completada exitosamente!")
    print(f"📄 Archivo generado: {os.path.abspath(ARCHIVO_SALIDA)}")
    print(f"📊 Tamaño: {os.path.getsize(ARCHIVO_SALIDA) / 1024:.2f} KB")
    print(f"📝 Total de líneas: {len(lineas_salida)}")

if __name__ == "__main__":
    generar_auditoria()
